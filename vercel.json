{
  "version": 2,
  "builds": [
    {
      "src": "elif_universe/elif_platform/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "elif_universe/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "elif_universe/elif_platform/wsgi.py"
    }
  ]
}
